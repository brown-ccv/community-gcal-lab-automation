# Environment Variables Template
# Copy this file to .env for local development.

# Server configuration
PORT=3000
NODE_ENV=development

# Authentication mode
# proxy: rely on upstream identity (Cloud Run authenticated invocations/IAP)
# oauth: app handles Google OAuth login via /auth/google
AUTH_MODE=proxy

# Optional app OAuth credentials (only needed when AUTH_MODE=oauth)
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Session security
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-random-session-secret-here

# Domain restriction (case-sensitive, no @)
ALLOWED_DOMAIN=brown.edu

# Development toggle
# NEVER enable in production.
BYPASS_AUTH=false

# Demo toggle (simulate calendar operations)
DEMO_MODE=true

# IAP / proxy identity + group enforcement
# Set REQUIRE_GROUP_MEMBERSHIP=true to require users in ALLOWED_GROUP_MEMBERS.
REQUIRE_GROUP_MEMBERSHIP=false
# Preferred production path: enforce via Google Group lookup.
# Example: carelab-group@brown.edu
REQUIRED_GOOGLE_GROUP=
# Delegated Google Workspace admin used to query group membership.
GOOGLE_ADMIN_USER_EMAIL=
# Service account JSON string with domain-wide delegation enabled.
# Keep this in Secret Manager for production, not plaintext files.
GOOGLE_ADMIN_SERVICE_ACCOUNT_JSON=
# Optional membership cache TTL for Directory API lookups (ms).
GROUP_MEMBERSHIP_CACHE_TTL_MS=300000
# Comma-separated allowlist until direct Google Group lookup is added.
# Example: person1@brown.edu,person2@brown.edu
ALLOWED_GROUP_MEMBERS=

# Calendar configuration
REMINDER_CALENDAR_ID=your-reminder-calendar-id@group.calendar.google.com
RETENTION_CALENDAR_ID=your-retention-calendar-id@group.calendar.google.com

# Service account JSON for Calendar API access.
# In production, set via Secret Manager env var, not plaintext files.
GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON=
# Optional: impersonate a Workspace user (requires domain-wide delegation).
GOOGLE_CALENDAR_IMPERSONATE_USER=

# Calendar invite behavior
PRODUCTION_ATTENDEE_EMAIL=
ENABLE_ATTENDEES=false

# Legacy fallback accepted by server for calendar auth as well.
# You can reuse the same JSON secret for both group lookup and calendar operations.
# GOOGLE_ADMIN_SERVICE_ACCOUNT_JSON=
